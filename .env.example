# Public site URL — used for canonical/hreflang/OG metadata, sitemap, robots, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://terrasomething.com

# Enquiry email delivery (Resend). If unset, submissions are logged server-side
# and the form still succeeds, but no email is sent.
# Create a key at https://resend.com and verify your sending domain.
RESEND_API_KEY=
# Optional: verified sender. Defaults to Resend's shared onboarding address.
ENQUIRY_FROM_EMAIL="Terra Something <noreply@terrasomething.com>"
